<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="001" author="fivednevnik">
        <!-- Таблица пользователей -->
        <createTable tableName="users">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(50)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="password" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="email" type="VARCHAR(100)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="role" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Таблица классов -->
        <createTable tableName="classes">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="year" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Таблица предметов -->
        <createTable tableName="subjects">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(100)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
        </createTable>

        <!-- Таблица оценок -->
        <createTable tableName="grades">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="student_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_grades_student" references="users(id)"/>
            </column>
            <column name="subject_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_grades_subject" references="subjects(id)"/>
            </column>
            <column name="grade" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="TEXT"/>
        </createTable>

        <!-- Таблица расписания -->
        <createTable tableName="schedule">
            <column name="id" type="INTEGER">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="class_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_schedule_class" references="classes(id)"/>
            </column>
            <column name="subject_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_schedule_subject" references="subjects(id)"/>
            </column>
            <column name="teacher_id" type="INTEGER">
                <constraints nullable="false" foreignKeyName="fk_schedule_teacher" references="users(id)"/>
            </column>
            <column name="day_of_week" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="lesson_number" type="INTEGER">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <!-- Индексы -->
        <createIndex indexName="idx_users_username" tableName="users">
            <column name="username"/>
        </createIndex>
        <createIndex indexName="idx_users_email" tableName="users">
            <column name="email"/>
        </createIndex>
        <createIndex indexName="idx_grades_student" tableName="grades">
            <column name="student_id"/>
        </createIndex>
        <createIndex indexName="idx_grades_subject" tableName="grades">
            <column name="subject_id"/>
        </createIndex>
        <createIndex indexName="idx_schedule_class" tableName="schedule">
            <column name="class_id"/>
        </createIndex>
    </changeSet>
</databaseChangeLog> 